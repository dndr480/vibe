#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
src="$script_dir/hello-efi/hello.c"
out_dir="$script_dir/pxe/www"
build_dir="$script_dir/pxe/run/hello-efi-build"

mkdir -p "$out_dir" "$build_dir"

gcc \
  -ffreestanding \
  -fshort-wchar \
  -fno-stack-protector \
  -fno-stack-check \
  -fno-asynchronous-unwind-tables \
  -fno-ident \
  -fpic \
  -mno-red-zone \
  -maccumulate-outgoing-args \
  -c "$src" \
  -o "$build_dir/hello.o"

ld \
  -mi386pep \
  --subsystem 10 \
  -dll \
  -nostdlib \
  -e efi_main \
  "$build_dir/hello.o" \
  -o "$out_dir/hello.efi"

strip "$out_dir/hello.efi"
file "$out_dir/hello.efi"
