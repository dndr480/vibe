#!/usr/bin/env bash
set -euo pipefail

host="${PXENODE1_PXE_SSH_HOST:-192.168.1.218}"
key="${PXENODE1_PXE_SSH_KEY:-$HOME/.ssh/id_ed25519}"
known_hosts="${PXENODE1_PXE_KNOWN_HOSTS:-/dev/null}"

exec ssh \
  -i "$key" \
  -o BatchMode=yes \
  -o ConnectTimeout=8 \
  -o StrictHostKeyChecking=no \
  -o GlobalKnownHostsFile=/dev/null \
  -o LogLevel=ERROR \
  -o UserKnownHostsFile="$known_hosts" \
  root@"$host" \
  "$@"
